# Neon Postgres – Dashboard → Connection Details
# DATABASE_URL = "pooled" connection string (für Laufzeitbetrieb)
# DIRECT_URL   = "direct"/unpooled connection string (nur für Migrationen)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js Secret – z. B. erzeugen mit: openssl rand -base64 32
AUTH_SECRET=""

# Auf Vercel nötig, damit Auth.js dem Host vertraut
AUTH_TRUST_HOST=true

# Wird automatisch gesetzt, sobald ein Vercel Blob Store mit dem Projekt verbunden ist
BLOB_READ_WRITE_TOKEN=""
